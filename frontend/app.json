{
  "expo": {
    "name": "MemoryLane",
    "slug": "memorylane",
    "scheme": "memorylane",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5FBF7"
    },
    "extra": {
      "eas": {
        "projectId": "72125389-abd1-48a8-92fa-99af7986623d"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memorylane.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "MemoryLane needs your camera to scan the QR code and link to a patient's account.",
        "NSLocationWhenInUseUsageDescription": "MemoryLane shares the patient's live location with their care team while the patient app is open.",
        "NSFaceIDUsageDescription": "MemoryLane uses Face ID to help the patient get back to their photos easily.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    
    "owner": "halilbagosi",
    
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5FBF7"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.memorylane.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MemoryLane shares the patient's live location with their care team while the patient app is open."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MemoryLane needs your camera to scan the QR code and link to a patient's account."
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": {
                "light": "#9BE7B4",
                "dark": "#9BE7B4"
              },
              "colorControlActivated": {
                "light": "#9BE7B4",
                "dark": "#9BE7B4"
              },
              "textColorPrimary": {
                "light": "#F5FBF7",
                "dark": "#F5FBF7"
              },
              "textColorSecondary": {
                "light": "#AEBDAF",
                "dark": "#AEBDAF"
              },
              "windowBackground": {
                "light": "#17231D",
                "dark": "#17231D"
              }
            }
          }
        }
      ],
      "./plugins/withAndroidGradleJvm.js",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1006582252554-9h90j34o6g4tphhu6drp49r3d20vohfu"
        }
      ]
    ]
  }
}
