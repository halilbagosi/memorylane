{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "scheme": "memorylane",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "MemoryLane needs your camera to scan the QR code and link to a patient's account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "MemoryLane needs your camera to scan the QR code and link to a patient's account."
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "colorAccent": { "light": "#2D4F3E" },
              "colorControlActivated": { "light": "#2D4F3E" },
              "textColorPrimary": { "light": "#1A1A1A" },
              "textColorSecondary": { "light": "#666666" },
              "windowBackground": { "light": "#F2F0E6" }
            }
          }
        }
      ]
    ]
  }
}
