# Copy this file to .env.local and set the value for your machine/scenario.
# .env.local is gitignored so each developer keeps their own copy.
#
# ──────────────────────────────────────────────────────────────────────────────
# SCENARIO A — iOS Simulator (Mac only)
#   Leave this commented out. The app defaults to http://localhost:3000 on iOS.
#
# SCENARIO B — Android Emulator (Mac OR Windows)
#   Leave this commented out. The app defaults to http://10.0.2.2:3000 on Android,
#   which is Android's built-in alias for the host machine's localhost.
#
# SCENARIO C — Physical Android/iOS device on the same Wi-Fi
#   Uncomment the line below and replace with your computer's LAN IP.
#   Mac:     run `ipconfig getifaddr en0`  in Terminal
#   Windows: run `ipconfig`               in Command Prompt → find IPv4 Address
#
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.X:3000
#
# SCENARIO D — Deployed / staging backend
#   Point everyone at the same server and nobody ever needs to change anything.
#
# EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.com
#
# Login omits deviceLabel by default (compatible with APIs that forbid unknown fields).
# After redeploying a backend that accepts deviceLabel on POST /auth/login, enable:
#
# EXPO_PUBLIC_INCLUDE_LOGIN_DEVICE_LABEL=true
#
# ─── Google Sign-In ──────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# The WEB client ID is used as the audience when requesting the idToken
# The IOS client ID is the OAuth 2.0 client ID for iOS
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# ──────────────────────────────────────────────────────────────────────────────
