generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaregiverStatus {
  ACTIVE
  PENDING_DELETION
  DEACTIVATED
}

model Caregiver {
  id                String          @id @default(uuid())
  name              String
  surname           String
  email             String          @unique
  passwordHash      String          @map("password_hash")
  avatarUrl         String?         @map("avatar_url") @db.Text
  pushToken         String?         @map("push_token") @db.Text
  status            CaregiverStatus @default(ACTIVE)
  scheduledDeleteAt DateTime?       @map("scheduled_delete_at")
  createdAt         DateTime        @default(now()) @map("created_at")

  patientCaregivers     PatientCaregiver[]
  uploadedMedia         Media[]
  authSessions          AuthSession[]
  passwordResetRequests PasswordResetRequest[]
  createdPatients       Patient[]
  passwordHistory       PasswordHistory[]
  sentDelegations       DelegationRequest[]    @relation("SentDelegations")
  receivedDelegations   DelegationRequest[]    @relation("ReceivedDelegations")
  sentRoleRequests      RoleRequest[]          @relation("SentRoleRequests")
  receivedRoleRequests  RoleRequest[]          @relation("ReceivedRoleRequests")
  notifications         Notification[]

  @@map("caregivers")
}

model Notification {
  id          String           @id @default(uuid())
  caregiverId String           @map("caregiver_id")
  type        NotificationType
  title       String
  body        String
  declineReason String?          @map("decline_reason")
  createdAt   DateTime         @default(now()) @map("created_at")
  readAt      DateTime?        @map("read_at")

  caregiver   Caregiver        @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum DelegationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  SECONDARY_ADDED
  DEVICE_PAIRED
  PATIENT_DELETED
  DELEGATION_ACCEPTED
  DELEGATION_DECLINED
  DELEGATION_CANCELLED
  DELEGATION_COMPLETED
  ROLE_REQUEST_RECEIVED
  ROLE_REQUEST_APPROVED
  ROLE_REQUEST_DECLINED
}

enum RoleRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model DelegationRequest {
  id              String           @id @default(uuid())
  patientId       String           @map("patient_id")
  fromCaregiverId String           @map("from_caregiver_id")
  toCaregiverId   String           @map("to_caregiver_id")
  status          DelegationStatus @default(PENDING)
  declineReason   String?          @map("decline_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  respondedAt     DateTime?        @map("responded_at")

  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fromCaregiver Caregiver @relation("SentDelegations",     fields: [fromCaregiverId], references: [id], onDelete: Cascade)
  toCaregiver   Caregiver @relation("ReceivedDelegations", fields: [toCaregiverId],   references: [id], onDelete: Cascade)

  @@map("delegation_requests")
}

model RoleRequest {
  id               String            @id @default(uuid())
  patientId        String            @map("patient_id")
  requesterId      String            @map("requester_id")
  currentPrimaryId String            @map("current_primary_id")
  status           RoleRequestStatus @default(PENDING)
  declineReason    String?           @map("decline_reason")
  createdAt        DateTime          @default(now()) @map("created_at")
  respondedAt      DateTime?         @map("responded_at")

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  requester      Caregiver @relation("SentRoleRequests",     fields: [requesterId],      references: [id], onDelete: Cascade)
  currentPrimary Caregiver @relation("ReceivedRoleRequests", fields: [currentPrimaryId], references: [id], onDelete: Cascade)

  @@map("role_requests")
}

model PasswordHistory {
  id           String    @id @default(uuid())
  caregiverId  String    @map("caregiver_id")
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  caregiver    Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@map("password_history")
}

model Patient {
  id                 String              @id @default(uuid())
  createdBy          String              @map("created_by") //to the primary caregiver
  name               String
  surname            String
  dateOfBirth        DateTime?           @map("date_of_birth") @db.Date
  avatarUrl          String?             @map("avatar_url") @db.Text
  
  // code scanned by tablet/phone of patient to identify this specific patient
  patientJoinCode    String              @unique @map("patient_join_code")    
  
  paired             Boolean             @default(false)
  biometricRecoveryEnabled Boolean       @default(false) @map("biometric_recovery_enabled")
  quizModes          String[]            @default(["NAME", "AGE", "RELATIONSHIP"]) @map("quiz_modes")
  createdAt          DateTime            @default(now()) @map("created_at")
  deviceToken        String?             @map("device_token")

  creator             Caregiver           @relation(fields: [createdBy], references: [id])
  patientCaregivers   PatientCaregiver[]
  media               Media[]
  quizSessions        QuizSession[]
  analyticsSnapshots  AnalyticsSnapshot[]
  delegationRequests  DelegationRequest[]
  roleRequests        RoleRequest[]

  @@map("patients")
}

model PatientCaregiver {
  caregiverId String    @map("caregiver_id")
  patientId   String    @map("patient_id")
  isPrimary   Boolean   @default(false) @map("is_primary")
  joinedAt    DateTime  @default(now()) @map("joined_at")

  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])
  patient     Patient   @relation(fields: [patientId], references: [id])

  @@id([caregiverId, patientId])
  @@map("patient_caregivers")
}

enum MediaKind {
  PHOTO
  AUDIO
  VIDEO
  DOCUMENT
}

enum MediaStatus {
  PENDING_UPLOAD
  READY
  FAILED
}

enum MediaCollection {
  MEMORY
  QUIZ
}

model Media {
  id           String      @id @default(uuid())
  publicId     String      @unique @default(uuid()) @map("public_id")
  patientId    String      @map("patient_id")
  caregiverId  String?     @map("caregiver_id")

  kind         MediaKind
  status       MediaStatus @default(PENDING_UPLOAD)
  collection   MediaCollection @default(MEMORY)

  // Quiz identity data. Required by the service for collection=QUIZ.
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  relationshipType String?  @map("relationship_type")
  decoyNames       String[] @default([]) @map("decoy_names")

  // Memory story data. Used by the caregiver Media Manager.
  note               String?  @db.Text
  eventYear          Int?     @map("event_year")
  isApproximateYear  Boolean  @default(false) @map("is_approximate_year")
  memoryCategory     String?  @map("memory_category")
  isActive           Boolean  @default(true) @map("is_active")

  // Object storage reference (random, non-guessable).
  // Never returned to clients.
  storageKey   String      @unique @map("storage_key")

  contentType  String      @map("content_type")
  byteSize     Int         @map("byte_size")

  // Envelope encryption metadata.
  // wrappedDek = AES-256-GCM(masterKey, dek) with dekIv + dekTag.
  // payloadIv/payloadTag describe the AES-256-GCM encryption of the
  // file payload at rest using the per-file DEK.
  wrappedDek   String      @map("wrapped_dek")
  dekIv        String      @map("dek_iv")
  dekTag       String      @map("dek_tag")
  payloadIv    String      @map("payload_iv")
  payloadTag   String?     @map("payload_tag")
  algorithm    String      @default("AES-256-GCM")
  keyVersion   String      @default("v1") @map("key_version")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  patient      Patient       @relation(fields: [patientId], references: [id])
  caregiver    Caregiver?    @relation(fields: [caregiverId], references: [id])
  quizAttempts QuizAttempt[]

  @@index([patientId, createdAt])
  @@map("media")
}

model QuizSession {
  id           String        @id @default(uuid())
  patientId    String        @map("patient_id")
  startedAt    DateTime      @default(now()) @map("started_at")
  endedAt      DateTime?     @map("ended_at")

  patient      Patient       @relation(fields: [patientId], references: [id])
  quizAttempts QuizAttempt[]

  @@map("quiz_sessions")
}

model QuizAttempt {
  id              String      @id @default(uuid())
  sessionId       String      @map("session_id")
  mediaId         String      @map("media_id")
  firstTapCorrect Boolean     @map("first_tap_correct")
  totalTaps       Int         @map("total_taps")
  timeToCorrectMs Int         @map("time_to_correct_ms")
  attemptedAt     DateTime    @default(now()) @map("attempted_at")
  endAttemptAt    DateTime?   @map("end_attempt_at")

  session         QuizSession @relation(fields: [sessionId], references: [id])
  media           Media       @relation(fields: [mediaId], references: [id])

  @@map("quiz_attempts")
}

model AuthSession {
  id          String    @id @default(uuid())
  caregiverId String    @map("caregiver_id")
  tokenHash   String    @map("token_hash")
  deviceLabel String?   @map("device_label")
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")

  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])

  @@map("auth_sessions")
}

model PasswordResetRequest {
  id          String    @id @default(uuid())
  caregiverId String    @map("caregiver_id")
  resetToken  String    @map("reset_token")
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")

  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])

  @@map("password_reset_requests")
}

model AnalyticsSnapshot {
  id                 String   @id @default(uuid())
  patientId          String   @map("patient_id")
  date               DateTime @db.Date
  totalCorrect       Int      @map("total_correct")
  totalIncorrect     Int      @map("total_incorrect")
  totalAttempts      Int      @map("total_attempts")
  accuracyPercentage Float    @map("accuracy_percentage")
  averageTimeMs      Int      @map("average_time_ms")
  createdAt          DateTime @default(now()) @map("created_at")

  patient            Patient  @relation(fields: [patientId], references: [id])

  @@map("analytics_snapshots")
}
