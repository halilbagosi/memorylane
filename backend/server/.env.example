# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/memorylane

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Port the server listens on
PORT=8080

# ─── Google OAuth ─────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ─── Apple Sign-In ────────────────────────────────────────────────────────
# Your iOS app bundle identifier (e.g. com.yourteam.memorylane)
APPLE_BUNDLE_ID=your.bundle.id

# ─── Email / SMTP (for password-reset codes) ──────────────────────────────
# Leave blank to fall back to console logging in non-production
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password

# ─── Application-level encryption (patient name/surname) ──────────────────
# AES-256-CBC. Set ENCRYPTION_KEY to the ACTIVE key used for NEW writes.
#
# Older ciphertext (from a rotated key): add backward-compatible decrypt keys without
# changing ENCRYPTION_KEY, then existing rows decrypt correctly; on read, rows are
# re-encrypted with the current ENCRYPTION_KEY automatically.
#
# Option A — multiple legacy strings separated by ||| (three pipes):
# ENCRYPTION_KEY_LEGACY_PIPE=previous-passphrase|||even-older-passphrase
#
# Option B — numbered fallback keys:
# ENCRYPTION_KEY_LEGACY_1=previous-passphrase
# ENCRYPTION_KEY_LEGACY_2=older-passphrase
#
# In production, omit the dev fallback: always set ENCRYPTION_KEY explicitly.
ENCRYPTION_KEY=replace-with-a-long-random-secret

# ─── Encrypted media upload pipeline ──────────────────────────────────────
# Master key wrapping per-file Data Encryption Keys (DEKs). Required in
# production. 32-byte hex (64 chars) is preferred; any other string is
# stretched via SHA-256.
MEDIA_MASTER_KEY=replace-with-32-byte-hex-or-strong-passphrase

# Secret used to HMAC-sign short-lived upload/download URLs. Falls back to
# JWT_SECRET if unset, but a dedicated secret is strongly recommended.
MEDIA_SIGNED_URL_SECRET=replace-with-a-long-random-secret

# Storage driver: only "local" is implemented in this project. The local
# driver stores ciphertext under MEDIA_STORAGE_LOCAL_PATH.
MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_LOCAL_PATH=./uploads/media

# Lifetime of signed upload/download URLs (seconds). Capped server-side at 3600.
MEDIA_SIGNED_URL_TTL_SECONDS=600

# Per-kind upload limits (bytes).
MEDIA_MAX_BYTES_IMAGE=10485760
MEDIA_MAX_BYTES_AUDIO=26214400

# AI quiz-photo verification. The backend uses AWS Rekognition DetectFaces
# before encrypting QUIZ photos, and Sharp for optional headshot cropping.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key

# The AWS principal must allow these Rekognition actions:
# rekognition:DetectFaces
# rekognition:CreateCollection
# rekognition:SearchFacesByImage
# rekognition:IndexFaces
# rekognition:DeleteFaces

# Optional tuning for the four quiz-photo rules.
QUIZ_FACE_MIN_CONFIDENCE=85
QUIZ_FACE_MIN_SHARPNESS=45
QUIZ_FACE_MIN_BRIGHTNESS=35
QUIZ_FACE_MAX_YAW=15
QUIZ_FACE_MAX_ROLL=15
QUIZ_FACE_MIN_AREA_BEFORE_CROP=0.5
QUIZ_BLOCK_DUPLICATE_FACES=false
QUIZ_FACE_MATCH_THRESHOLD=90

# Optional: explicit base URL the API uses when issuing signed URLs.
# If unset, the request's host/proto headers are used.
PUBLIC_API_BASE_URL=
