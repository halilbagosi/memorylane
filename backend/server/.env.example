# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/memorylane

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Port the server listens on
PORT=8080

# ─── Google OAuth ─────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ─── Apple Sign-In ────────────────────────────────────────────────────────
# Your iOS app bundle identifier (e.g. com.yourteam.memorylane)
APPLE_BUNDLE_ID=your.bundle.id

# ─── Email / SMTP (for password-reset codes) ──────────────────────────────
# Leave blank to fall back to console logging in non-production
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
