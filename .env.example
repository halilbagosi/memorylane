# Postgres
POSTGRES_USER=memorylane
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=memorylane

# API
JWT_SECRET=replace-with-long-random-secret
PORT=8080

# Google OAuth
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Apple Sign-In
APPLE_BUNDLE_ID=

# AWS Rekognition (required for quiz photo face verification)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (for password-reset emails — optional, falls back to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
